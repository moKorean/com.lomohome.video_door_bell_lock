  "flow": {
    "triggers": [
      {
        "id": "doorbell_rang",
        "title": {
          "en": "Someone rang the doorbell",
          "ko": "초인종이 눌리면"
        },
        "hint": {
          "en": "Triggers when the linked doorbell sensor is activated.",
          "ko": "연동된 초인종 센서가 활성화되면 실행됩니다."
